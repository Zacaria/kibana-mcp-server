{
  "sources": [
    {
      "id": "app_logs",
      "name": "Application logs",
      "description": "Application-side execution logs for core workflows.",
      "tags": ["application", "logs", "runtime"],
      "timeField": "@timestamp",
      "backend": {
        "kind": "kibana_internal_search_es",
        "path": "/internal/search/es",
        "index": ["app-logs-*"]
      },
      "schema": {
        "kind": "kibana_data_views_fields",
        "index": ["app-logs-*"]
      },
      "fieldHints": [
        {
          "name": "traceId",
          "aliases": ["trace_id", "correlation_id"],
          "description": "Correlation id for one workflow execution."
        },
        {
          "name": "region",
          "aliases": ["location"],
          "description": "Region or deployment segment for the event."
        },
        {
          "name": "tenantId",
          "aliases": ["tenant_id"],
          "description": "Tenant or customer identifier involved in the workflow."
        }
      ],
      "defaultTextFields": ["message", "event.original"],
      "evidenceFields": ["traceId", "region", "tenantId", "operation", "duration_ms"]
    },
    {
      "id": "api_logs",
      "name": "API request logs",
      "description": "Request and response logs for HTTP APIs.",
      "tags": ["api", "http", "latency"],
      "timeField": "@timestamp",
      "backend": {
        "kind": "kibana_internal_search_es",
        "path": "/internal/search/es",
        "index": ["api-logs-*"]
      },
      "schema": {
        "kind": "kibana_data_views_fields",
        "index": ["api-logs-*"]
      },
      "fieldHints": [
        {
          "name": "route",
          "description": "Normalized route or path pattern."
        },
        {
          "name": "statusCode",
          "aliases": ["status_code"],
          "description": "HTTP response code."
        }
      ],
      "defaultTextFields": ["message"],
      "evidenceFields": ["route", "statusCode", "duration_ms"]
    },
    {
      "id": "workflow_metrics",
      "name": "Workflow metrics logs",
      "description": "Structured log events such as WORKFLOW_RELOAD_STATS and CACHE_REFRESH_PHASES.",
      "tags": ["metrics", "workflow", "structured"],
      "timeField": "@timestamp",
      "backend": {
        "kind": "kibana_internal_search_es",
        "path": "/internal/search/es",
        "index": ["workflow-metrics-*"]
      },
      "schema": {
        "kind": "kibana_data_views_fields",
        "index": ["workflow-metrics-*"]
      },
      "fieldHints": [
        {
          "name": "eventName",
          "aliases": ["event_name"],
          "description": "Logical event marker for metrics-style logs."
        },
        {
          "name": "step",
          "description": "Workflow step name."
        }
      ],
      "defaultTextFields": ["message", "eventName"],
      "evidenceFields": ["eventName", "step", "items_scanned", "items_reloaded", "duration_ms"]
    }
  ]
}
